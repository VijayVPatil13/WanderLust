<% layout('/layouts/boilerplate') %>
<body>
    <div class="col-md-8 offset-md-2 mt-4">
        <div class="booking-empty-state">
            <h3 class="bookings-page-title">Complete Payment</h3>
            <p class="bookings-page-subtitle mb-3">Secure your booking to confirm your stay.</p>

            <h3 class="bookings-page-title mb-1">Total Amount: <%= formatCurrency(booking.totalPrice) %></h3>
            <p class="booking-muted mb-3">Secure payment powered by Razorpay</p>

            <button id="pay-btn" class="btn booking-now-btn">Pay Now</button>
        </div>
    </div>

    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
        const payBtn = document.getElementById("pay-btn");
        const bookingId = "<%= booking._id %>";

        const resetButton = () => {
            payBtn.disabled = false;
            payBtn.textContent = "Pay Now";
        };

        const options = {
            key: "<%= key_id %>",
            amount: "<%= order.amount %>",
            currency: "INR",
            name: "WanderLust",
            description: "Booking Payment",
            order_id: "<%= order.id %>",
            modal: {
                ondismiss: function () {
                    resetButton();
                }
            },
            handler: async function (response) {
                payBtn.disabled = true;
                payBtn.textContent = "Verifying...";

                try {
                    const verifyResponse = await fetch("/api/bookings/verify-payment", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify({
                            bookingId,
                            razorpay_order_id: response.razorpay_order_id,
                            razorpay_payment_id: response.razorpay_payment_id,
                            razorpay_signature: response.razorpay_signature
                        })
                    });

                    const result = await verifyResponse.json();
                    if (result.success) {
                        window.location.href = result.redirectUrl || "/bookings";
                        return;
                    }

                    resetButton();
                    alert(result.message || "Payment verification failed. Please try again.");
                } catch (err) {
                    resetButton();
                    alert("Unable to verify payment right now. Please try again.");
                }
            }
        };

        const rzp = new Razorpay(options);
        rzp.on("payment.failed", async function (response) {
            console.error(response.error);

            try {
                await fetch(`/api/bookings/${bookingId}/payment-failed`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({ razorpay_order_id: "<%= order.id %>" })
                });
            } catch (err) {
                console.error(err);
            }

            alert("Payment failed. Try again.");
            window.location.href = "/bookings";
        });

        payBtn.onclick = function () {
            this.textContent = "Processing...";
            this.disabled = true;
            rzp.open();
        };
    </script>
</body>
