<nav class="navbar navbar-expand-md bg-body-light sticky-top" id="main-navbar">
  <div class="container-fluid" style="max-width:1280px;margin:0 auto;padding:0 1rem;">
    <!-- Brand -->
    <a class="navbar-brand" href="/">
      <i class="fa-regular fa-compass"></i>
      <span>WanderLust</span>
    </a>

    <!-- Hamburger toggler -->
    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarMain"
      aria-controls="navbarMain"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Collapsible content -->
    <div class="collapse navbar-collapse" id="navbarMain">

      <!-- Left: Explore link -->
      <div class="navbar-nav me-auto">
        <a class="nav-link" href="/listings">
          <i class="fa-solid fa-compass-drafting me-1" style="font-size:0.9rem;"></i>Explore
        </a>
      </div>

      <!-- Centre: Search form -->
      <form class="navbar-search-form d-flex my-2 my-md-0 mx-md-3" role="search" action="/listings" method="GET">
        <input
          class="form-control search-box me-2"
          type="search"
          name="search"
          placeholder="Search destinations..."
          value="<%= typeof req !== 'undefined' ? req.query.search : '' %>"
          aria-label="Search destinations"
        />
        <input type="hidden" name="category" value="<%= typeof req !== 'undefined' ? req.query.category : '' %>">
        <input type="hidden" name="location" value="<%= typeof req !== 'undefined' ? req.query.location : '' %>">
        <button class="btn search-btn" type="submit" aria-label="Search">
          <i class="fa-solid fa-magnifying-glass"></i><span class="d-none d-sm-inline">Search</span>
        </button>
      </form>

      <!-- Right: Nav links -->
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/listings/new">
          <i class="fa-solid fa-plus-circle me-1" style="font-size:0.9rem;color:var(--wl-primary);"></i>Airbnb your home
        </a>
        <% if(!currUser) { %>
          <a class="nav-link fw-semibold" href="/signup">Sign up</a>
          <a class="nav-link fw-semibold" href="/login">Login</a>
        <% } %>
        <% if(currUser) { %>
          <a class="nav-link fw-semibold" href="/bookings">
            <i class="fa-regular fa-calendar-check me-1" style="font-size:0.9rem;"></i>My Bookings
          </a>
          <a class="nav-link fw-semibold" href="/logout">Logout</a>
        <% } %>
      </div>

    </div>
  </div>
</nav>
