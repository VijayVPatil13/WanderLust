<% layout('/layouts/boilerplate') %>
<body>
    <script>
        const mapToken = "<%= process.env.MAP_TOKEN %>";
        const listing = <%- JSON.stringify(listing) %>;
        const bookedDates = <%- JSON.stringify(bookedDates || []) %>;
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

    <div class="listing-container">
        <!-- LEFT COLUMN: image + details + reviews -->
        <div class="listing-left">
            <h2 class="mb-3" style="font-size:clamp(1.2rem,3vw,1.75rem);font-weight:700;word-break:break-word;"><%= listing.title %></h2>

            <!-- Listing Image -->
            <img src="<%= listing.image.url %>" class="show-img w-100" alt="<%= listing.title %>">

            <!-- Meta details -->
            <div class="mt-3">
                <p class="listing-owner mb-1">
                    <i class="fa-solid fa-user-tie me-1"></i> Owned by <em><%= listing.owner.username %></em>
                </p>
                <p class="listing-description mt-2"><%= listing.description %></p>
                <p class="listing-price-tag mt-2">
                    <i class="fa-solid fa-indian-rupee-sign me-1" style="color:var(--wl-primary);"></i>
                    <%= formatCurrency(listing.price) %>/night
                </p>
                <p class="listing-location">
                    <i class="fa-solid fa-location-dot me-1" style="color:var(--wl-primary);"></i>
                    <%= listing.location %>, <%= listing.country %>
                </p>

                <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
                    <div class="listing-action-btns mt-3">
                        <a href="/listings/<%= listing._id %>/edit" class="btn edit-btn">
                            <i class="fa-solid fa-pen-to-square me-1"></i> Edit Listing
                        </a>
                        <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" class="m-0">
                            <button class="btn delete-btn" type="submit">
                                <i class="fa-solid fa-trash me-1"></i> Delete Listing
                            </button>
                        </form>
                    </div>
                <% } %>
            </div>

            <hr class="my-4">

            <!-- Leave a Review -->
            <% if(currUser) { %>
                <div class="mb-4">
                    <h4 class="mb-3">Leave a review</h4>
                    <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                        <div class="mb-3">
                            <label for="rating" class="form-label">Rating</label>
                            <fieldset class="starability-slot">
                                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                <label for="first-rate1" title="Terrible">1 star</label>
                                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                <label for="first-rate2" title="Not good">2 stars</label>
                                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                <label for="first-rate3" title="Average">3 stars</label>
                                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                <label for="first-rate4" title="Very good">4 stars</label>
                                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                <label for="first-rate5" title="Amazing">5 stars</label>
                            </fieldset>
                        </div>
                        <div class="mb-3">
                            <label for="comment" class="form-label">Comment</label>
                            <textarea name="review[comment]" id="comment" rows="4" class="form-control" required placeholder="Share your experience..."></textarea>
                            <div class="invalid-feedback">Please add a comment for your review.</div>
                        </div>
                        <button class="btn add-btn" type="submit">Submit Review</button>
                    </form>
                </div>
                <hr class="my-4">
            <% } %>

            <!-- All Reviews -->
            <% if(listing.reviews.length > 0) { %>
                <div class="mb-3">
                    <h4>All Reviews</h4>
                </div>
                <div class="row g-3">
                    <% for(review of listing.reviews) { %>
                        <div class="col-12 col-md-6 review-col">
                            <div class="review-card">
                                <h5 class="card-title">@<%= review.author.username %></h5>
                                <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                                <p class="card-text" style="font-size:0.9rem;color:#444;"><%= review.comment %></p>
                                <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" class="mt-2 mb-0">
                                    <button class="btn add-btn btn-sm" style="font-size:0.82rem;padding:6px 14px;">Delete</button>
                                </form>
                            </div>
                        </div>
                    <% } %>
                </div>
                <hr class="my-4">
            <% } %>
        </div>

        <!-- RIGHT COLUMN: Booking card -->
        <div class="listing-right">
            <div
                class="booking-section-card"
                data-nightly-price="<%= listing.price %>"
                data-base-guests="<%= pricingConfig.BASE_INCLUDED_GUESTS %>"
                data-extra-guest-fee="<%= pricingConfig.EXTRA_GUEST_FEE %>"
            >
                <div class="booking-section-header">
                    <h4>Book this stay</h4>
                    <p class="booking-muted">Secure your dates now, payment can be completed later.</p>
                    <p class="booking-pricing-hint">Price includes up to <%= pricingConfig.BASE_INCLUDED_GUESTS %> guests.</p>
                </div>
                <% if(currUser) { %>
                    <form action="/bookings/<%= listing._id %>" method="POST" class="row g-3 mt-1 booking-form">
                        <div class="col-12 col-sm-6 col-lg-12">
                            <label for="checkIn" class="form-label booking-label">Check-in</label>
                            <div class="booking-input-wrap">
                                <i class="fa-regular fa-calendar booking-input-icon"></i>
                                <input type="text" id="checkIn" name="checkIn" class="form-control booking-date-input" placeholder="Select check-in" required>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6 col-lg-12">
                            <label for="checkOut" class="form-label booking-label">Check-out</label>
                            <div class="booking-input-wrap">
                                <i class="fa-regular fa-calendar booking-input-icon"></i>
                                <input type="text" id="checkOut" name="checkOut" class="form-control booking-date-input" placeholder="Select check-out" required>
                            </div>
                        </div>
                        <div class="col-12">
                            <label for="guests" class="form-label booking-label">Guests</label>
                            <div class="booking-input-wrap">
                                <i class="fa-solid fa-user-group booking-input-icon"></i>
                                <input type="number" id="guests" name="guests" class="form-control booking-guest-input" min="1" value="1" required>
                            </div>
                        </div>
                        <div class="col-12 mt-1">
                            <div class="booking-price-summary">
                                <p class="booking-price-line booking-price-base-line">
                                    <span id="bookingBasePriceLine"><%= formatCurrency(listing.price) %> x 0 nights = <%= formatCurrency(0) %></span>
                                </p>
                                <p class="booking-price-line booking-price-extra-line d-none" id="bookingExtraPriceLine"></p>
                                <p class="booking-extra-note d-none" id="bookingExtraGuestNote">Additional charges apply for extra guests.</p>
                                <div class="booking-price-total-row">
                                    <span>Total</span>
                                    <strong id="bookingTotalDisplay"><%= formatCurrency(0) %></strong>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 mt-2">
                            <button class="btn booking-now-btn" type="submit">Book Now</button>
                        </div>
                    </form>
                <% } else { %>
                    <p class="card-text mt-3 booking-muted">Please <a href="/login" style="color:var(--wl-primary);font-weight:600;">log in</a> to make a booking.</p>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Map section -->
    <div class="container" style="max-width:1200px;padding:0 1rem 2rem;">
        <h4 class="mb-3">Where you'll be</h4>
        <div id="map"></div>
    </div>

    <script src="/js/map.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="/js/booking-ui.js"></script>
</body>
