<% layout('/layouts/boilerplate') %>
<body>
    <div class="row mt-2">
        <div class="col-8 offset-2">   
            <h3>Create a New Listing</h3>
            <form action="/listings" method="POST" novalidate class="needs-validation">
                <div class="mb-3">
                    <label for="title" class="form-label">Title:</label>
                    <input type="text" id="title" class="form-control" name="listing[title]" required placeholder="Add your place name">
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description:</label>
                    <textarea id="description" class="form-control" name="listing[description]" required rows="3"></textarea>
                </div>
                <div class="mb-3">
                    <label for="image" class="form-label">Image: </label>
                    <input type="text" id="image" class="form-control" name="listing[image]" placeholder="Enter image url/link">
                </div>
                <div class="mb-3">
                    <label for="location" class="form-label">Location:</label>
                    <input type="text" id="location" class="form-control" name="listing[location]" required placeholder="Dandeli, Karnataka">
                </div>
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price:</label>
                        <input type="number" id="price" class="form-control" name="listing[price]" required min="0" step="0.01" placeholder="1000">
                    </div>
                    <div class="mb-3 col-md-8">
                        <label for="country" class="form-label">Country:</label>
                        <input type="text" id="country" class="form-control" name="listing[country]" required placeholder="India">
                    </div>
                </div>
                <div class="d-grid gap-2 col-6 mx-auto mb-3 mt-3">
                    <button class="btn btn-dark add-btn" type="submit">Create Listing</button>
                </div>
            </form>
        </div>
    </div>
</body>