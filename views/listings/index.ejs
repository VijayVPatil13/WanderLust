<% layout('/layouts/boilerplate') %>
<body>
    <!-- <h3>All Listings</h3> -->
    <!-- <form action="/listings/new" method="GET">
        <button>Add new place</button>
    </form> -->
    <form id="categoryForm" action="/listings" method="GET">
        <input type="hidden" name="category" id="categoryInput" value="<%= req.query.category || '' %>">
        <!-- Preserve navbar search state -->
        <input type="hidden" name="search" value="<%= req.query.search || '' %>">
        <input type="hidden" name="location" value="<%= req.query.location || '' %>">

        <div id="filters">
            <div class="filter-container">
                <% filters.forEach(f => { %>
                    <div class="filter <%= req.query.category === f.name ? 'active' : '' %>" onclick="selectCategory('<%= f.name %>')">
                        <div><i class="fa-solid <%= f.icon %>"></i></div>
                        <p><%= f.name %></p>
                    </div>
                <% }) %>
            </div>
            <div class="tax-toggle">
                <div class="form-check-reverse form-switch">
                    <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                    <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
                </div>
            </div>
        </div>
    </form>
    <% if (listings.length === 0) { %>
        <div class="no-results">
            <h3>No places found</h3>
            <p>Try adjusting your search or filters.</p>
            <a href="/listings" class="btn btn-outline-dark rounded-pill mt-2">Clear Filters</a>
        </div>
    <% } else { %>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 mt-3 g-4">
            <% for (let listing of listings) { %>
                <div class="col mb-4">
                    <a href="/listings/<%= listing.id %>" class="text-decoration-none text-dark">
                        <div class="card col listing-card">
                            <img src="<%= listing.image.url %>" class="card-img-top" alt="listing image">
                            <div class="card-img-overlay"></div>
                            <div class="card-body">
                                <p class="card-text">
                                    <b><%= listing.title %></b><br>
                                    &#x20b9; <%= listing.price.toLocaleString("en-IN") %>/night
                                    <i class="tax-info">&nbsp; &nbsp; +18% GST</i>
                                </p>
                            </div>
                        </div>
                    </a>
                </div>
            <% } %>
        </div>
    <% } %>

</body>

<script src="/js/taxSwitch.js"></script>

